# 이 파일을 복사하여 .env 로 사용하세요: cp .env.example .env

# PostgreSQL 연결 URL (asyncpg 드라이버)
DATABASE_URL=postgresql+asyncpg://routeon:routeon@db:5432/routeon

# Kakao REST API 키 (https://developers.kakao.com 에서 발급)
KAKAO_API_KEY=

# 한국도로공사 OpenAPI 인증키 (https://data.ex.co.kr 에서 발급) — 고속도로 휴게소 시드에 필요
EX_API_KEY=

# JWT 서명 키 — 배포 시 반드시 변경
SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# 디버그 모드 (개발 시 true, 운영 시 false)
DEBUG=false
